# Environment variables for events-app
# Copy this file to .env and fill in your values.
# Never commit .env — it's in .gitignore.

# Supabase
# Use the legacy eyJ... JWT format for the anon key.
# The sb_publishable... format does NOT work with the custom Supabase client.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_KEY=eyJ...

# Email (Resend)
# API key for sending confirmation emails via Resend.
VITE_RESEND_API_KEY=re_...
